# Required
DISCORD_CLIENT_ID=
DISCORD_TOKEN=
# Comma-separated free-tier Google API keys for triage/general model rotation (at least one required)
GOOGLE_FREE_API_KEYS=key1,key2,key3
# Single paid Google API key for the search model (Google Search grounding is paid-only)
GOOGLE_PAID_API_KEY=keyN
DATABASE_URL=postgresql://genie:genie@localhost:5432/genie

# Optional
# Pino accepted log level string
LOG_LEVEL=info
# Write structured JSON logs to ./logs/<timestamp>-pino.log in parallel with console output
# Can be viewed with formatting as `cat logs/<log_name>.log | bunx pino-pretty -c | less -R`
FILE_LOG=false
# Minutes before Gemini file expiry to treat a file as stale and re-upload (only used when UPLOAD_ATTACHMENT_MODE=upload)
# Discord ID of a previous bot instance whose messages will be loaded as "model/AI" messages, also in config.yaml
PREVIOUS_BOT_ID=

# Instrumentation
# NOTE: disable for tests to fix errors with fetch interceptions
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your-api-key>
LANGSMITH_PROJECT='genie-ai'
# Reduces latency, only non-serverless environments
LANGCHAIN_CALLBACKS_BACKGROUND=true

# SENTRY_URL is used for instrumentation with Sentry.
SENTRY_URL=
# Enable Sentry debug mode (verbose Sentry SDK logging)
SENTRY_DEBUG=false