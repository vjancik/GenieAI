# Required
DISCORD_TOKEN=
GOOGLE_API_KEY=
DATABASE_URL=postgresql://genie:genie@localhost:5432/genie

# Optional
TRIAGE_THINKING_LEVEL=minimal
# Useful for debugging to see LLM thoughts in the console and LangSmith traces, but can increase latency as
# Gemini models modify / regenerate thought tokens to prevent scraping from other providers
INCLUDE_LLM_THOUGHTS=false
LOG_LEVEL=info
# Write structured JSON logs to ./logs/<timestamp>-pino.log in parallel with console output
FILE_LOG=false
# "inline" (base64 in message, high memory) or "upload" (Gemini Files API, streaming)
UPLOAD_ATTACHMENT_MODE=inline
# Maximum total MB of inline attachment data per message / across conversation history
MAX_INLINE_ATTACHMENT_SZ_MB=100
# Minutes before Gemini file expiry to treat a file as stale and re-upload (only used when UPLOAD_ATTACHMENT_MODE=upload)
GEMINI_FILE_STALE_THRESHOLD_MINUTES=60
# NODE_ENV=production

# NOTE: disable for tests to fix errors with fetch interceptions
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your-api-key>
LANGSMITH_PROJECT='genie-ai'