DISCORD_TOKEN='your_discord_token_here'
DISCORD_PREFIX='!'
GEMINI_API_KEY='your_gemini_api_key_here'

LOG_LEVEL='debug'
LOG_FORMAT='text'
LOG_COLOR='true'

BENCHMARK_DISCORD_CHANNEL_ID='your_benchmark_channel_id_here'

# Database configuration
DB_USER='genie'
DB_PASSWORD='genie_pass'
DB_NAME='genie_ai'
DB_PORT='5432'
DATABASE_URL='postgresql://genie:genie_pass@localhost:5432/genie_ai'

# OpenTelemetry (Grafana Cloud Direct OTLP)
OTEL_SERVICE_NAME='genie-ai-bot'
OTEL_EXPORTER_OTLP_ENDPOINT='https://otlp-gateway-prod-us-central-0.grafana.net/otlp'
OTEL_EXPORTER_OTLP_HEADERS='Authorization=Basic <base64-encoded-auth>'
OTEL_EXPORTER_OTLP_PROTOCOL='http/protobuf'
OTEL_TRACES_EXPORTER='otlp'
OTEL_RESOURCE_ATTRIBUTES='service.namespace=genie-ai,deployment.environment=development'
OTEL_NODE_RESOURCE_DETECTORS='env,host,os'

# Toggle for auto-instrumenting modules (http, pg, fs, etc.)
NODE_AUTO_INSTRUMENTATION='true'
