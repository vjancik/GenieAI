{
	"name": "genieaibot",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "bun run src/index.ts",
		"start:otel": "bun run --preload ./src/instrumentation.ts src/index.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint",
		"lint:fix": "biome lint --fix",
		"format": "biome format",
		"format:fix": "biome format --write",
		"codecheck": "biome check",
		"codecheck:staged": "biome check --staged",
		"codecheck:fix": "biome check --fix",
		"codecheck:ci": "biome ci .",
		"benchmark:discord": "bun run src/benchmarks/discord-latency.bench.ts",
		"benchmark:all": "bun src/benchmarks/discord-latency.bench.ts",
		"db:up": "docker-compose up -d",
		"db:down": "docker-compose down",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "bun --env-file=.env.local run src/infrastructure/database/migrate.ts",
		"db:studio": "bun --env-file=.env.local run drizzle-kit studio",
		"test:db:up": "docker-compose --env-file .env.test -f docker-compose.test.yml up -d",
		"test:db:down": "docker-compose --env-file .env.test -f docker-compose.test.yml down",
		"test": "bun run test:unit && bun run test:integration",
		"test:unit": "bun test tests/unit",
		"test:integration": "bun --env-file=.env.test run src/infrastructure/database/migrate.ts && bun test tests/integration",
		"test:coverage": "bun --env-file=.env.test run src/infrastructure/database/migrate.ts && bun --env-file=.env.test test --coverage tests/unit tests/integration",
		"test:coverage:lcov": "bun --env-file=.env.test run src/infrastructure/database/migrate.ts && bun --env-file=.env.test test --coverage --coverage-reporter=lcov tests/unit tests/integration"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.14",
		"@types/bun": "^1.3.8",
		"@types/pg": "^8.16.0",
		"drizzle-kit": "^0.31.8",
		"mitata": "^1.0.34"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@google/genai": "^1.39.0",
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/auto-instrumentations-node": "^0.69.0",
		"@opentelemetry/exporter-metrics-otlp-http": "^0.211.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
		"@opentelemetry/instrumentation-pino": "^0.57.0",
		"@opentelemetry/sdk-metrics": "^2.5.0",
		"@opentelemetry/sdk-node": "^0.211.0",
		"@opentelemetry/sdk-trace-node": "^2.5.0",
		"@types/uuid": "^10.0.0",
		"discord.js": "^14.25.1",
		"drizzle-orm": "^0.45.1",
		"pg": "^8.18.0",
		"pino": "^10.3.0",
		"pino-opentelemetry-transport": "^2.0.0",
		"uuid": "^13.0.0"
	}
}
