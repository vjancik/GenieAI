{
    "name": "genie-ai",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "start": "bun src/index.ts",
        "start:instrumented": "bun --preload ./src/infrastructure/instrumentation/sentry/instrumentation.ts src/index.ts",
        "typecheck": "tsc --noEmit",
        "codecheck:fix": "biome check --fix",
        "test": "bun test",
        "local:prod:up": "docker compose -f docker-compose.local-prod.yml up -d --build --timeout 120",
        "local:prod:down": "docker compose -f docker-compose.local-prod.yml down --timeout 120",
        "db:studio": "drizzle-kit studio",
        "db:up": "docker compose -f docker-compose.local-dev.yml up -d",
        "db:down": "docker compose -f docker-compose.local-dev.yml down",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:test:up": "docker compose -f docker-compose.test.yml up -d",
        "db:test:down": "docker compose -f docker-compose.test.yml down",
        "db:test:migrate": "cross-env DATABASE_URL=postgresql://genie_test:genie_test@localhost:5433/genie_test drizzle-kit migrate",
        "commands:register": "bun scripts/discord/registerCommands.ts"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.5",
        "@types/bun": "latest",
        "@types/katex": "^0.16.8",
        "@types/turndown": "^5.0.6",
        "cross-env": "^10.1.0",
        "drizzle-kit": "^0.31.9",
        "pg": "^8.19.0",
        "pino-pretty": "^13.1.3"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@google/genai": "^1.44.0",
        "@langchain/core": "^1.1.34",
        "@langchain/google": "0.1.7",
        "@langchain/langgraph": "^1.2.0",
        "@langchain/tavily": "^1.2.0",
        "@sentry/bun": "^10.42.0",
        "discord.js": "^14.25.1",
        "drizzle-orm": "^0.45.1",
        "katex": "^0.16.40",
        "langchain": "^1.2.36",
        "marked": "^17.0.5",
        "marked-katex-extension": "^5.1.7",
        "pino": "^10.3.1",
        "playwright": "^1.58.2",
        "turndown": "^7.2.2",
        "zod": "^4.3.6"
    }
}
