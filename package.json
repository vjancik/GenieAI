{
    "name": "genieai",
    "version": "1.1.0",
    "description": "Google Gemini based Discord AI Bot that works with rotating Free Tier API keys.",
    "author": "Viktor Jancik",
    "license": "AGPL-3.0-only",
    "repository": {
        "type": "git",
        "url": "https://github.com/vjancik/GenieAI"
    },
    "homepage": "https://github.com/vjancik/GenieAI",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "start": "bun src/index.ts",
        "start:instrumented": "bun --preload ./src/infrastructure/instrumentation/sentry/instrumentation.ts src/index.ts",
        "typecheck": "tsc --noEmit",
        "codecheck:fix": "biome check --fix",
        "test": "bun test --env-file .env.test",
        "test:coverage": "bun test --env-file .env.test --coverage",
        "test:coverage:lcov": "bun test --env-file .env.test --coverage --coverage-reporter=lcov",
        "local:up": "docker compose -f docker-compose.local.yml up -d --build --timeout 120",
        "local:down": "docker compose -f docker-compose.local.yml down --timeout 120",
        "db:studio": "drizzle-kit studio",
        "db:up": "docker compose -f docker-compose/docker-compose.dev-db.yml up -d",
        "db:down": "docker compose -f docker-compose/docker-compose.dev-db.yml down",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:test:up": "docker compose -f docker-compose/docker-compose.test-db.yml up -d",
        "db:test:down": "docker compose -f docker-compose/docker-compose.test-db.yml down",
        "db:test:migrate": "cross-env DATABASE_URL=postgresql://genie_test:genie_test@localhost:5433/genie_test drizzle-kit migrate",
        "commands:register": "bun scripts/discord/registerCommands.ts",
        "prepack": "husky"
    },
    "lint-staged": {
        "*.ts": "bun codecheck:fix"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.10",
        "@types/bun": "1.3.11",
        "@types/katex": "^0.16.8",
        "@types/turndown": "^5.0.6",
        "cross-env": "^10.1.0",
        "drizzle-kit": "^0.31.10",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "pg": "^8.20.0",
        "pino-pretty": "^13.1.3"
    },
    "peerDependencies": {
        "typescript": "^6.0.2"
    },
    "dependencies": {
        "@google/genai": "^1.47.0",
        "@langchain/core": "^1.1.37",
        "@langchain/google": "^0.1.9",
        "@langchain/langgraph": "^1.2.6",
        "@langchain/tavily": "^1.2.0",
        "@sentry/bun": "^10.46.0",
        "discord.js": "^14.25.1",
        "drizzle-orm": "^0.45.2",
        "katex": "^0.16.44",
        "lru-cache": "^11.2.7",
        "marked": "^17.0.5",
        "marked-katex-extension": "^5.1.7",
        "pino": "^10.3.1",
        "playwright": "^1.58.2",
        "turndown": "^7.2.2",
        "zod": "^4.3.6"
    }
}
