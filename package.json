{
  "name": "genieaibot",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "start:otel": "bun run --preload ./src/instrumentation.ts src/index.ts",
    "typecheck": "tsc --noEmit",
    "benchmark:discord": "bun run src/benchmarks/discord-latency.bench.ts",
    "benchmark:all": "bun src/benchmarks/discord-latency.bench.ts",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/infrastructure/database/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "mitata": "^1.0.34"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@google/genai": "^1.39.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.211.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/instrumentation-pino": "^0.57.0",
    "@opentelemetry/sdk-metrics": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/sdk-trace-node": "^2.5.0",
    "@types/uuid": "^10.0.0",
    "discord.js": "^14.25.1",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.18.0",
    "pino": "^10.3.0",
    "pino-opentelemetry-transport": "^2.0.0",
    "uuid": "^13.0.0"
  }
}